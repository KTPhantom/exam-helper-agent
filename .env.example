# Google Gemini API Key (free: https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Brevo API Key (free: https://brevo.com)
BREVO_API_KEY=your_brevo_api_key_here

# Email Configuration
# EMAIL_FROM must be your verified sender email in your Brevo account
EMAIL_FROM=your-sender-email@gmail.com
EMAIL_TO=recipient1@gmail.com,recipient2@gmail.com

# Optional: Telegram (for public use later)
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHANNEL_ID=@YourChannelName

# Optional: Buttondown (for newsletter later)
# BUTTONDOWN_API_KEY=your_buttondown_api_key_here
